@page
@model CardapioWeb.Views.ListarProdutosModel

@{
    ViewData["Title"] = "ListarProdutos";
}

<h1>ListarProdutos</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Produto[0].Nome)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Produto[0].Descricao_Curta)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Produto[0].Descricao_Detalhada)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Produto[0].Preco)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Produto[0].Produto_Preferido)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Produto[0].Em_Estoque)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Produto) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Nome)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Descricao_Curta)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Descricao_Detalhada)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Preco)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Produto_Preferido)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Em_Estoque)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
